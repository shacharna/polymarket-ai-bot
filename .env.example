# ============================================
# Aggressive Stock Trading Bot Configuration
# ============================================

# Alpaca Markets API (get keys at https://alpaca.markets)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic API (for AI analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot (for remote control)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Watchlist (comma-separated stock tickers)
WATCHLIST=AAPL,TSLA,NVDA,MSFT,AMZN,META,GOOGL,AMD,NFLX,SPY,QQQ,SOFI,PLTR,COIN,MARA

# Trading Mode
TRADING_MODE=aggressive
PAPER_TRADING=true
LOG_LEVEL=INFO

# Position Sizing
INITIAL_BALANCE=500.0
MAX_POSITION_SIZE=500.0
MAX_POSITION_PCT=0.25
MAX_CONCURRENT_POSITIONS=5
CONFIDENCE_THRESHOLD=55

# Risk Limits
DAILY_LOSS_LIMIT=150.0
DAILY_LOSS_LIMIT_PCT=0.30
RISK_PER_TRADE=10.0
MAX_DAILY_TRADES=50
MAX_TRADES_PER_CYCLE=3

# Stop Loss / Take Profit
STOP_LOSS_PCT=-8.0
TAKE_PROFIT_PCT=15.0

# Trailing Stop
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION=0.05
TRAILING_STOP_DISTANCE=0.03

# Scanning
SCAN_INTERVAL=60
MARKET_HOURS_ONLY=true
ALLOW_AI_ONLY_TRADES=true
ALLOW_STRATEGY_ONLY_TRADES=true
